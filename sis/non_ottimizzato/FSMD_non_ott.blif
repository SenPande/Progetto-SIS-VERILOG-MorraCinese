.model FSMD
.inputs  PRIMO1 PRIMO0 SECONDO1 SECONDO0 INIZIA
.outputs MANCHE1 MANCHE0 PARTITA1 PARTITA0

.subckt DATAPATH INIZIA=INIZIA PRIMO1=PRIMO1 PRIMO0=PRIMO0 SECONDO1=SECONDO1 SECONDO0=SECONDO0 MANCHE1=MANCHE1 MANCHE0=MANCHE0 FLAG_MANCHE1=FLAG_MANCHE1 FLAG_MANCHE0=FLAG_MANCHE0
.subckt FSM INIZIA=INIZIA MANCHE1=MANCHE1 MANCHE0=MANCHE0 FLAG_MANCHE1=FLAG_MANCHE1 FLAG_MANCHE0=FLAG_MANCHE0 PARTITA1=PARTITA1 PARTITA0=PARTITA0

.search DATAPATH.blif
.search FSM.blif

.end
